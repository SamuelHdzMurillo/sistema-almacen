{"timestamp":"2026-03-19T19:15:46+01:00","request_id":"5065ebf6-72f7-4b4d-8a84-83b6b7b01e8e","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.207,"op":"SELECT","write":false,"tabla":null,"sql":"SELECT id FROM almacenes WHERE id = ? LIMIT 1","params_raw":[2],"resumen":"usuario=Administrador GET /sistema-almacen/index.php -> SELECT tabla? params=[2]","ok":true}
{"timestamp":"2026-03-19T19:15:46+01:00","request_id":"5065ebf6-72f7-4b4d-8a84-83b6b7b01e8e","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.429,"op":"SELECT","write":false,"tabla":null,"sql":"\n            SELECT e.id, e.referencia, e.factura, e.fecha, prov.nombre AS persona, e.estado,\n                   'in' AS tipo, de.cantidad, p.nombre AS item_nombre,\n                   e.created_at, e.created_by, u.nombre AS created_by_nombre\n            FROM entradas e\n            LEFT JOIN catalogo_proveedor prov ON prov.id = e.proveedor_id\n            JOIN detalle_entradas de ON de.entrada_id = e.id AND (de.estado = 'activa' OR de.estado IS NULL)\n            JOIN productos p ON p.id = de.producto_id\n            LEFT JOIN usuarios u ON u.id = e.created_by\n            WHERE 1=1 AND e.almacen_id = ?\n         ORDER BY e.created_at DESC, de.id DESC LIMIT 10","params_raw":[2],"resumen":"usuario=Administrador GET /sistema-almacen/index.php -> SELECT tabla? params=[2]","ok":true}
{"timestamp":"2026-03-19T19:15:46+01:00","request_id":"5065ebf6-72f7-4b4d-8a84-83b6b7b01e8e","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.377,"op":"SELECT","write":false,"tabla":null,"sql":"\n            SELECT s.id, s.referencia, s.fecha, rec.nombre AS persona, s.estado,\n                   'out' AS tipo, ds.cantidad, p.nombre AS item_nombre,\n                   s.created_at, s.created_by, u.nombre AS created_by_nombre,\n                   qe.nombre AS nombre_entrega, pl.nombre AS plantel_nombre, rec.nombre AS nombre_receptor\n            FROM salidas s\n            LEFT JOIN catalogo_quien_entrega qe ON qe.id = s.quien_entrega_id\n            LEFT JOIN catalogo_plantel pl ON pl.id = s.plantel_id\n            LEFT JOIN catalogo_receptor rec ON rec.id = s.receptor_id\n            JOIN detalle_salidas ds ON ds.salida_id = s.id\n            JOIN productos p ON p.id = ds.producto_id\n            LEFT JOIN usuarios u ON u.id = s.created_by\n            WHERE 1=1 AND s.almacen_id = ?\n         ORDER BY s.created_at DESC, ds.id DESC LIMIT 10","params_raw":[2],"resumen":"usuario=Administrador GET /sistema-almacen/index.php -> SELECT tabla? params=[2]","ok":true}
{"timestamp":"2026-03-19T19:15:46+01:00","request_id":"5065ebf6-72f7-4b4d-8a84-83b6b7b01e8e","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.21,"op":"SELECT","write":false,"tabla":null,"sql":"SELECT id FROM almacenes WHERE id = ? LIMIT 1","params_raw":[2],"resumen":"usuario=Administrador GET /sistema-almacen/index.php -> SELECT tabla? params=[2]","ok":true}
