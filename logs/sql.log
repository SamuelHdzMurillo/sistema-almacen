{"timestamp":"2026-03-18T19:42:20+01:00","request_id":"d7b59153-3455-4f1d-8aed-c850dc6ead1d","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.382,"op":"SELECT","write":false,"tabla":null,"sql":"SELECT e.id, e.referencia, e.factura, e.fecha, e.estado, e.created_at, e.updated_at, e.created_by, u.nombre AS created_by_nombre, prov.nombre AS proveedor_nombre, qr.nombre AS quien_recibe_nombre FROM entradas e LEFT JOIN usuarios u ON u.id = e.created_by LEFT JOIN catalogo_proveedor prov ON prov.id = e.proveedor_id LEFT JOIN catalogo_quien_recibe_entrada qr ON qr.id = e.quien_recibe_id WHERE e.id = ?","params_raw":[19],"resumen":"usuario=Administrador GET /sistema-almacen/ver-transaccion.php -> SELECT tabla? params=[19]","ok":true}
{"timestamp":"2026-03-18T19:42:20+01:00","request_id":"d7b59153-3455-4f1d-8aed-c850dc6ead1d","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.517,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT de.id, de.producto_id, de.cantidad, COALESCE(de.estado, 'activa') AS estado, p.nombre AS producto_nombre, p.unidad\n        FROM detalle_entradas de\n        JOIN productos p ON p.id = de.producto_id\n        WHERE de.entrada_id = ?\n        ORDER BY de.id\n    ","params_raw":[19],"resumen":"usuario=Administrador GET /sistema-almacen/ver-transaccion.php -> SELECT tabla? params=[19]","ok":true}
{"timestamp":"2026-03-18T19:43:29+01:00","request_id":"7d356d1b-8cb9-4591-b45b-609d3e88903c","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.591,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT e.id, e.referencia, e.fecha, e.estado, e.created_at,\n               u.nombre AS created_by_nombre,\n               prov.nombre AS proveedor_nombre, qr.nombre AS quien_recibe_nombre\n        FROM entradas e\n        LEFT JOIN usuarios u ON u.id = e.created_by\n        LEFT JOIN catalogo_proveedor prov ON prov.id = e.proveedor_id\n        LEFT JOIN catalogo_quien_recibe_entrada qr ON qr.id = e.quien_recibe_id\n        WHERE e.estado = 'completada'\n          AND YEAR(e.fecha) = ?\n          AND MONTH(e.fecha) = ?\n        ORDER BY e.fecha ASC, e.id ASC\n    ","params_raw":[2026,3],"resumen":"usuario=Administrador GET /sistema-almacen/inventario.php -> SELECT tabla? params=[2026,3]","ok":true}
