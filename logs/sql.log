{"timestamp":"2026-03-19T19:24:05+01:00","request_id":"500e7d04-9d1a-4a50-898e-aa5d3dafec80","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.989,"op":"SELECT","write":false,"tabla":null,"sql":"\n            SELECT e.id, e.referencia, e.factura, e.fecha, prov.nombre AS persona, e.estado,\n                   'in' AS tipo, de.cantidad, p.nombre AS item_nombre,\n                   e.created_at, e.created_by, u.nombre AS created_by_nombre\n            FROM entradas e\n            LEFT JOIN catalogo_proveedor prov ON prov.id = e.proveedor_id\n            JOIN detalle_entradas de ON de.entrada_id = e.id AND (de.estado = 'activa' OR de.estado IS NULL)\n            JOIN productos p ON p.id = de.producto_id\n            LEFT JOIN usuarios u ON u.id = e.created_by\n            WHERE 1=1 AND e.almacen_id = ?\n         ORDER BY e.created_at DESC, de.id DESC LIMIT 10","params_raw":[1],"resumen":"usuario=Administrador GET /sistema-almacen/index.php -> SELECT tabla? params=[1]","ok":true}
{"timestamp":"2026-03-19T19:24:05+01:00","request_id":"500e7d04-9d1a-4a50-898e-aa5d3dafec80","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.661,"op":"SELECT","write":false,"tabla":null,"sql":"\n            SELECT s.id, s.referencia, s.fecha, rec.nombre AS persona, s.estado,\n                   'out' AS tipo, ds.cantidad, p.nombre AS item_nombre,\n                   s.created_at, s.created_by, u.nombre AS created_by_nombre,\n                   qe.nombre AS nombre_entrega, pl.nombre AS plantel_nombre, rec.nombre AS nombre_receptor\n            FROM salidas s\n            LEFT JOIN catalogo_quien_entrega qe ON qe.id = s.quien_entrega_id\n            LEFT JOIN catalogo_plantel pl ON pl.id = s.plantel_id\n            LEFT JOIN catalogo_receptor rec ON rec.id = s.receptor_id\n            JOIN detalle_salidas ds ON ds.salida_id = s.id\n            JOIN productos p ON p.id = ds.producto_id\n            LEFT JOIN usuarios u ON u.id = s.created_by\n            WHERE 1=1 AND s.almacen_id = ?\n         ORDER BY s.created_at DESC, ds.id DESC LIMIT 10","params_raw":[1],"resumen":"usuario=Administrador GET /sistema-almacen/index.php -> SELECT tabla? params=[1]","ok":true}
{"timestamp":"2026-03-19T19:24:05+01:00","request_id":"500e7d04-9d1a-4a50-898e-aa5d3dafec80","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.441,"op":"SELECT","write":false,"tabla":null,"sql":"\n  SELECT COALESCE(SUM(de.cantidad), 0) AS t\n  FROM detalle_entradas de\n  JOIN entradas e ON e.id = de.entrada_id\n  WHERE e.estado = 'completada'\n    AND e.almacen_id = ?\n    AND (de.estado = 'activa' OR de.estado IS NULL)\n","params_raw":[1],"resumen":"usuario=Administrador GET /sistema-almacen/index.php -> SELECT tabla? params=[1]","ok":true}
{"timestamp":"2026-03-19T19:24:05+01:00","request_id":"500e7d04-9d1a-4a50-898e-aa5d3dafec80","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.381,"op":"SELECT","write":false,"tabla":null,"sql":"\n  SELECT COALESCE(SUM(ds.cantidad), 0) AS t\n  FROM detalle_salidas ds\n  JOIN salidas s ON s.id = ds.salida_id\n  WHERE s.estado = 'completada'\n    AND s.almacen_id = ?\n","params_raw":[1],"resumen":"usuario=Administrador GET /sistema-almacen/index.php -> SELECT tabla? params=[1]","ok":true}
{"timestamp":"2026-03-19T19:24:05+01:00","request_id":"ec0ef0ee-1faa-4adf-b64e-a3cfd848d2a4","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.698,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT e.id, e.referencia, e.fecha, e.estado, e.created_at,\n               u.nombre AS created_by_nombre,\n               prov.nombre AS proveedor_nombre, qr.nombre AS quien_recibe_nombre\n        FROM entradas e\n        LEFT JOIN usuarios u ON u.id = e.created_by\n        LEFT JOIN catalogo_proveedor prov ON prov.id = e.proveedor_id\n        LEFT JOIN catalogo_quien_recibe_entrada qr ON qr.id = e.quien_recibe_id\n        WHERE e.estado = 'completada'\n          AND e.almacen_id = ?\n          AND YEAR(e.fecha) = ?\n          AND MONTH(e.fecha) = ?\n        ORDER BY e.fecha ASC, e.id ASC\n    ","params_raw":[1,2026,3],"resumen":"usuario=Administrador GET /sistema-almacen/inventario.php -> SELECT tabla? params=[1,2026,3]","ok":true}
