{"timestamp":"2026-03-20T20:19:06+01:00","request_id":"be1ac6ff-eb13-4647-b0b8-750057d40e1a","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":0.388,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT s.id, s.referencia, s.fecha, s.estado, s.created_at,\n               qe.nombre AS nombre_entrega, pl.nombre AS plantel_nombre, rec.nombre AS nombre_receptor,\n               u.nombre AS created_by_nombre\n        FROM salidas s\n        LEFT JOIN catalogo_quien_entrega qe ON qe.id = s.quien_entrega_id\n        LEFT JOIN catalogo_plantel pl ON pl.id = s.plantel_id\n        LEFT JOIN catalogo_receptor rec ON rec.id = s.receptor_id\n        LEFT JOIN usuarios u ON u.id = s.created_by\n        WHERE s.estado = 'completada'\n          AND s.almacen_id = ?\n          AND YEAR(s.fecha) = ?\n          AND MONTH(s.fecha) = ?\n        ORDER BY s.fecha ASC, s.id ASC\n    ","params_raw":[2,2026,3],"resumen":"usuario=Arturo GET /sistema-almacen/inventario.php -> SELECT tabla? params=[2,2026,3]","ok":true}
{"timestamp":"2026-03-20T20:19:06+01:00","request_id":"be1ac6ff-eb13-4647-b0b8-750057d40e1a","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":0.33,"op":"SELECT","write":false,"tabla":null,"sql":"\n            SELECT ds.cantidad, p.nombre AS producto_nombre, p.unidad\n            FROM detalle_salidas ds\n            JOIN productos p ON p.id = ds.producto_id\n            WHERE ds.salida_id = ?\n        ","params_raw":[2],"resumen":"usuario=Arturo GET /sistema-almacen/inventario.php -> SELECT tabla? params=[2]","ok":true}
