{"timestamp":"2026-03-18T19:58:01+01:00","request_id":"a78d6e75-b61f-4c21-a277-61767ecfbab9","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":1.349,"op":"SELECT","write":false,"tabla":null,"sql":"\n            SELECT e.id, e.referencia, e.factura, e.fecha, prov.nombre AS persona, e.estado,\n                   'in' AS tipo, de.cantidad, p.nombre AS item_nombre,\n                   e.created_at, e.created_by, u.nombre AS created_by_nombre\n            FROM entradas e\n            LEFT JOIN catalogo_proveedor prov ON prov.id = e.proveedor_id\n            JOIN detalle_entradas de ON de.entrada_id = e.id AND (de.estado = 'activa' OR de.estado IS NULL)\n            JOIN productos p ON p.id = de.producto_id\n            LEFT JOIN usuarios u ON u.id = e.created_by\n            WHERE 1=1\n         ORDER BY e.created_at DESC, de.id DESC LIMIT 50","params_raw":[],"resumen":"usuario=Administrador GET /sistema-almacen/transacciones.php -> SELECT tabla? params=[]","ok":true}
{"timestamp":"2026-03-18T19:58:01+01:00","request_id":"a78d6e75-b61f-4c21-a277-61767ecfbab9","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.945,"op":"SELECT","write":false,"tabla":null,"sql":"\n            SELECT s.id, s.referencia, s.fecha, rec.nombre AS persona, s.estado,\n                   'out' AS tipo, ds.cantidad, p.nombre AS item_nombre,\n                   s.created_at, s.created_by, u.nombre AS created_by_nombre,\n                   qe.nombre AS nombre_entrega, pl.nombre AS plantel_nombre, rec.nombre AS nombre_receptor\n            FROM salidas s\n            LEFT JOIN catalogo_quien_entrega qe ON qe.id = s.quien_entrega_id\n            LEFT JOIN catalogo_plantel pl ON pl.id = s.plantel_id\n            LEFT JOIN catalogo_receptor rec ON rec.id = s.receptor_id\n            JOIN detalle_salidas ds ON ds.salida_id = s.id\n            JOIN productos p ON p.id = ds.producto_id\n            LEFT JOIN usuarios u ON u.id = s.created_by\n            WHERE 1=1\n         ORDER BY s.created_at DESC, ds.id DESC LIMIT 50","params_raw":[],"resumen":"usuario=Administrador GET /sistema-almacen/transacciones.php -> SELECT tabla? params=[]","ok":true}
{"timestamp":"2026-03-18T19:58:02+01:00","request_id":"8e162fc9-cc2e-4589-8ec6-732258854542","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.427,"op":"SELECT","write":false,"tabla":null,"sql":"SELECT e.id, e.referencia, e.factura, e.fecha, e.estado, e.created_at, e.updated_at, e.created_by, u.nombre AS created_by_nombre, prov.nombre AS proveedor_nombre, qr.nombre AS quien_recibe_nombre FROM entradas e LEFT JOIN usuarios u ON u.id = e.created_by LEFT JOIN catalogo_proveedor prov ON prov.id = e.proveedor_id LEFT JOIN catalogo_quien_recibe_entrada qr ON qr.id = e.quien_recibe_id WHERE e.id = ?","params_raw":[19],"resumen":"usuario=Administrador GET /sistema-almacen/ver-transaccion.php -> SELECT tabla? params=[19]","ok":true}
{"timestamp":"2026-03-18T19:58:02+01:00","request_id":"8e162fc9-cc2e-4589-8ec6-732258854542","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.428,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT de.id, de.producto_id, de.cantidad, COALESCE(de.estado, 'activa') AS estado, p.nombre AS producto_nombre, p.unidad\n        FROM detalle_entradas de\n        JOIN productos p ON p.id = de.producto_id\n        WHERE de.entrada_id = ?\n        ORDER BY de.id\n    ","params_raw":[19],"resumen":"usuario=Administrador GET /sistema-almacen/ver-transaccion.php -> SELECT tabla? params=[19]","ok":true}
