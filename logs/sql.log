{"timestamp":"2026-03-20T20:17:58+01:00","request_id":"98226d48-9f90-48dd-8dc6-0e3c852b3274","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.453,"op":"SELECT","write":false,"tabla":null,"sql":"\r\n        SELECT COALESCE(SUM(de.cantidad), 0) AS t\r\n        FROM detalle_entradas de\r\n        JOIN entradas e ON e.id = de.entrada_id\r\n        WHERE e.estado != 'cancelada'\r\n          AND e.almacen_id = ?\r\n          AND (de.estado = 'activa' OR de.estado IS NULL)\r\n    ","params_raw":[1],"resumen":"usuario=Administrador GET /sistema-almacen/index.php -> SELECT tabla? params=[1]","ok":true}
{"timestamp":"2026-03-20T20:17:58+01:00","request_id":"98226d48-9f90-48dd-8dc6-0e3c852b3274","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.255,"op":"SELECT","write":false,"tabla":null,"sql":"\r\n        SELECT COALESCE(SUM(ds.cantidad), 0) AS t\r\n        FROM detalle_salidas ds\r\n        JOIN salidas s ON s.id = ds.salida_id\r\n        WHERE s.estado != 'cancelada'\r\n          AND s.almacen_id = ?\r\n    ","params_raw":[1],"resumen":"usuario=Administrador GET /sistema-almacen/index.php -> SELECT tabla? params=[1]","ok":true}
