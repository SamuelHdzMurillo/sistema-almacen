{"timestamp":"2026-03-19T20:01:21+01:00","request_id":"1ae60cda-ff10-4fdf-b4b9-dcada3f3ff3d","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.715,"op":"SELECT","write":false,"tabla":null,"sql":"\n            SELECT s.id, s.referencia, s.fecha, rec.nombre AS persona, s.estado,\n                   'out' AS tipo, ds.cantidad, p.nombre AS item_nombre,\n                   s.created_at, s.created_by, u.nombre AS created_by_nombre,\n                   qe.nombre AS nombre_entrega, pl.nombre AS plantel_nombre, rec.nombre AS nombre_receptor\n            FROM salidas s\n            LEFT JOIN catalogo_quien_entrega qe ON qe.id = s.quien_entrega_id\n            LEFT JOIN catalogo_plantel pl ON pl.id = s.plantel_id\n            LEFT JOIN catalogo_receptor rec ON rec.id = s.receptor_id\n            JOIN detalle_salidas ds ON ds.salida_id = s.id\n            JOIN productos p ON p.id = ds.producto_id\n            LEFT JOIN usuarios u ON u.id = s.created_by\n            WHERE 1=1 AND s.almacen_id = ?\n         ORDER BY s.created_at DESC, ds.id DESC LIMIT 50","params_raw":[2],"resumen":"usuario=Administrador GET /sistema-almacen/transacciones.php -> SELECT tabla? params=[2]","ok":true}
{"timestamp":"2026-03-19T20:01:21+01:00","request_id":"307b9cb1-6b3e-4042-a9bb-812991d7a149","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.526,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT e.id, e.referencia, e.fecha, e.estado, e.created_at,\n               u.nombre AS created_by_nombre,\n               prov.nombre AS proveedor_nombre, qr.nombre AS quien_recibe_nombre\n        FROM entradas e\n        LEFT JOIN usuarios u ON u.id = e.created_by\n        LEFT JOIN catalogo_proveedor prov ON prov.id = e.proveedor_id\n        LEFT JOIN catalogo_quien_recibe_entrada qr ON qr.id = e.quien_recibe_id\n        WHERE e.estado = 'completada'\n          AND e.almacen_id = ?\n          AND YEAR(e.fecha) = ?\n          AND MONTH(e.fecha) = ?\n        ORDER BY e.fecha ASC, e.id ASC\n    ","params_raw":[2,2026,3],"resumen":"usuario=Administrador GET /sistema-almacen/inventario.php -> SELECT tabla? params=[2,2026,3]","ok":true}
{"timestamp":"2026-03-19T20:01:21+01:00","request_id":"307b9cb1-6b3e-4042-a9bb-812991d7a149","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.349,"op":"SELECT","write":false,"tabla":null,"sql":"\n            SELECT de.cantidad, p.nombre AS producto_nombre, p.unidad\n            FROM detalle_entradas de\n            JOIN productos p ON p.id = de.producto_id\n            WHERE de.entrada_id = ? AND (de.estado = 'activa' OR de.estado IS NULL)\n        ","params_raw":[21],"resumen":"usuario=Administrador GET /sistema-almacen/inventario.php -> SELECT tabla? params=[21]","ok":true}
{"timestamp":"2026-03-19T20:01:21+01:00","request_id":"307b9cb1-6b3e-4042-a9bb-812991d7a149","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.363,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT s.id, s.referencia, s.fecha, s.estado, s.created_at,\n               qe.nombre AS nombre_entrega, pl.nombre AS plantel_nombre, rec.nombre AS nombre_receptor,\n               u.nombre AS created_by_nombre\n        FROM salidas s\n        LEFT JOIN catalogo_quien_entrega qe ON qe.id = s.quien_entrega_id\n        LEFT JOIN catalogo_plantel pl ON pl.id = s.plantel_id\n        LEFT JOIN catalogo_receptor rec ON rec.id = s.receptor_id\n        LEFT JOIN usuarios u ON u.id = s.created_by\n        WHERE s.estado = 'completada'\n          AND s.almacen_id = ?\n          AND YEAR(s.fecha) = ?\n          AND MONTH(s.fecha) = ?\n        ORDER BY s.fecha ASC, s.id ASC\n    ","params_raw":[2,2026,3],"resumen":"usuario=Administrador GET /sistema-almacen/inventario.php -> SELECT tabla? params=[2,2026,3]","ok":true}
