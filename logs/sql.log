{"timestamp":"2026-03-18T20:12:58+01:00","request_id":"3830ccd2-9aba-49fd-be3d-a927bccb131c","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.384,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT COALESCE(SUM(de.cantidad), 0) AS total\n        FROM detalle_entradas de\n        JOIN entradas e ON e.id = de.entrada_id\n        WHERE e.estado = 'completada' AND (de.estado = 'activa' OR de.estado IS NULL) AND YEAR(e.fecha) = ? AND MONTH(e.fecha) = ?\n    ","params_raw":[2026,3],"resumen":"usuario=Administrador GET /sistema-almacen/inventario.php -> SELECT tabla? params=[2026,3]","ok":true}
