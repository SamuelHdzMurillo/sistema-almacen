{"timestamp":"2026-03-19T21:45:08+01:00","request_id":"564fa3aa-3640-4cf4-8185-e1ba7540a8ca","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":0.819,"op":"SELECT","write":false,"tabla":null,"sql":"\n            SELECT e.id, e.referencia, e.factura, e.fecha, prov.nombre AS persona, e.estado,\n                   'in' AS tipo, de.cantidad, p.nombre AS item_nombre,\n                   e.created_at, e.created_by, u.nombre AS created_by_nombre\n            FROM entradas e\n            LEFT JOIN catalogo_proveedor prov ON prov.id = e.proveedor_id\n            JOIN detalle_entradas de ON de.entrada_id = e.id AND (de.estado = 'activa' OR de.estado IS NULL)\n            JOIN productos p ON p.id = de.producto_id\n            LEFT JOIN usuarios u ON u.id = e.created_by\n            WHERE 1=1 AND e.almacen_id = ?\n         ORDER BY e.created_at DESC, de.id DESC LIMIT 50","params_raw":[2],"resumen":"usuario=Arturo GET /sistema-almacen/transacciones.php -> SELECT tabla? params=[2]","ok":true}
{"timestamp":"2026-03-19T21:45:08+01:00","request_id":"564fa3aa-3640-4cf4-8185-e1ba7540a8ca","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":0.874,"op":"SELECT","write":false,"tabla":null,"sql":"\n            SELECT s.id, s.referencia, s.fecha, rec.nombre AS persona, s.estado,\n                   'out' AS tipo, ds.cantidad, p.nombre AS item_nombre,\n                   s.created_at, s.created_by, u.nombre AS created_by_nombre,\n                   qe.nombre AS nombre_entrega, pl.nombre AS plantel_nombre, rec.nombre AS nombre_receptor\n            FROM salidas s\n            LEFT JOIN catalogo_quien_entrega qe ON qe.id = s.quien_entrega_id\n            LEFT JOIN catalogo_plantel pl ON pl.id = s.plantel_id\n            LEFT JOIN catalogo_receptor rec ON rec.id = s.receptor_id\n            JOIN detalle_salidas ds ON ds.salida_id = s.id\n            JOIN productos p ON p.id = ds.producto_id\n            LEFT JOIN usuarios u ON u.id = s.created_by\n            WHERE 1=1 AND s.almacen_id = ?\n         ORDER BY s.created_at DESC, ds.id DESC LIMIT 50","params_raw":[2],"resumen":"usuario=Arturo GET /sistema-almacen/transacciones.php -> SELECT tabla? params=[2]","ok":true}
{"timestamp":"2026-03-19T21:45:09+01:00","request_id":"56b395d5-f5aa-41a5-b3b7-3d639fdf7b93","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":0.435,"op":"SELECT","write":false,"tabla":null,"sql":"\r\n        SELECT s.id, s.referencia, s.fecha, s.estado, s.created_at,\r\n               qe.nombre AS nombre_entrega, pl.nombre AS plantel_nombre, rec.nombre AS nombre_receptor,\r\n               u.nombre AS created_by_nombre\r\n        FROM salidas s\r\n        LEFT JOIN catalogo_quien_entrega qe ON qe.id = s.quien_entrega_id\r\n        LEFT JOIN catalogo_plantel pl ON pl.id = s.plantel_id\r\n        LEFT JOIN catalogo_receptor rec ON rec.id = s.receptor_id\r\n        LEFT JOIN usuarios u ON u.id = s.created_by\r\n        WHERE s.almacen_id = ?\r\n          AND (s.recibo_entrega_doc IS NULL OR s.recibo_entrega_doc = '')\r\n          AND s.estado != 'cancelada'\r\n        ORDER BY s.fecha DESC, s.created_at DESC\r\n    ","params_raw":[2],"resumen":"usuario=Arturo GET /sistema-almacen/recibos.php -> SELECT tabla? params=[2]","ok":true}
{"timestamp":"2026-03-19T21:45:09+01:00","request_id":"56b395d5-f5aa-41a5-b3b7-3d639fdf7b93","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":0.669,"op":"SELECT","write":false,"tabla":null,"sql":"\r\n        SELECT s.id, s.referencia, s.fecha, s.estado, s.created_at, s.recibo_entrega_doc,\r\n               qe.nombre AS nombre_entrega, pl.nombre AS plantel_nombre, rec.nombre AS nombre_receptor,\r\n               u.nombre AS created_by_nombre\r\n        FROM salidas s\r\n        LEFT JOIN catalogo_quien_entrega qe ON qe.id = s.quien_entrega_id\r\n        LEFT JOIN catalogo_plantel pl ON pl.id = s.plantel_id\r\n        LEFT JOIN catalogo_receptor rec ON rec.id = s.receptor_id\r\n        LEFT JOIN usuarios u ON u.id = s.created_by\r\n        WHERE s.almacen_id = ?\r\n          AND s.recibo_entrega_doc IS NOT NULL\r\n          AND s.recibo_entrega_doc != ''\r\n        ORDER BY s.fecha DESC, s.created_at DESC\r\n    ","params_raw":[2],"resumen":"usuario=Arturo GET /sistema-almacen/recibos.php -> SELECT tabla? params=[2]","ok":true}
{"timestamp":"2026-03-19T21:45:09+01:00","request_id":"c99b100e-a938-4b75-bb9f-aaddf0305902","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":0.626,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT e.id, e.referencia, e.factura, e.factura_doc, e.fecha, e.estado,\n               e.created_at, e.created_by,\n               u.nombre   AS created_by_nombre,\n               prov.nombre AS proveedor_nombre,\n               qr.nombre   AS quien_recibe_nombre\n        FROM entradas e\n        LEFT JOIN usuarios u ON u.id = e.created_by\n        LEFT JOIN catalogo_proveedor prov ON prov.id = e.proveedor_id\n        LEFT JOIN catalogo_quien_recibe_entrada qr ON qr.id = e.quien_recibe_id\n        WHERE e.almacen_id = ? AND e.factura_doc IS NOT NULL AND e.factura_doc != ''\n        ORDER BY e.fecha DESC, e.id DESC\n        LIMIT 200\n    ","params_raw":[2],"resumen":"usuario=Arturo GET /sistema-almacen/facturas.php -> SELECT tabla? params=[2]","ok":true}
{"timestamp":"2026-03-19T21:45:10+01:00","request_id":"828a9ffe-bbd0-44fd-8887-7dc4d0978187","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":1.98,"op":"SELECT","write":false,"tabla":null,"sql":"\r\n        SELECT p.id, p.codigo, p.nombre, p.unidad,\r\n          (SELECT COALESCE(SUM(de.cantidad), 0) FROM detalle_entradas de\r\n           JOIN entradas e ON e.id = de.entrada_id\r\n           WHERE de.producto_id = p.id\r\n             AND e.almacen_id = ?\r\n             AND e.estado != 'cancelada'\r\n             AND (de.estado = 'activa' OR de.estado IS NULL)) -\r\n          (SELECT COALESCE(SUM(ds.cantidad), 0) FROM detalle_salidas ds\r\n           JOIN salidas s ON s.id = ds.salida_id\r\n           WHERE ds.producto_id = p.id\r\n             AND s.almacen_id = ?\r\n             AND s.estado != 'cancelada') AS stock\r\n        FROM productos p\r\n    ","params_raw":[2,2],"resumen":"usuario=Arturo GET /sistema-almacen/nueva-salida.php -> SELECT tabla? params=[2,2]","ok":true}
