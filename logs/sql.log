{"timestamp":"2026-03-19T19:09:09+01:00","request_id":"3c5d596c-574a-4178-a7e3-d361b628fa46","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.185,"op":"SELECT","write":false,"tabla":null,"sql":"SELECT id FROM almacenes WHERE id = ? LIMIT 1","params_raw":[1],"resumen":"usuario=Administrador GET /sistema-almacen/index.php -> SELECT tabla? params=[1]","ok":true}
