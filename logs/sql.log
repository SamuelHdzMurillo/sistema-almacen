{"timestamp":"2026-03-18T19:20:56+01:00","request_id":"ac168eae-3a42-41ed-ace9-29cb89656433","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.265,"op":"SELECT","write":false,"tabla":null,"sql":"\n            SELECT de.cantidad, p.nombre AS producto_nombre, p.unidad\n            FROM detalle_entradas de\n            JOIN productos p ON p.id = de.producto_id\n            WHERE de.entrada_id = ? AND (de.estado = 'activa' OR de.estado IS NULL)\n        ","params_raw":[18],"resumen":"usuario=Administrador GET /sistema-almacen/inventario.php -> SELECT tabla? params=[18]","ok":true}
{"timestamp":"2026-03-18T19:20:56+01:00","request_id":"ac168eae-3a42-41ed-ace9-29cb89656433","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.317,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT s.id, s.referencia, s.fecha, s.estado, s.created_at,\n               qe.nombre AS nombre_entrega, pl.nombre AS plantel_nombre, rec.nombre AS nombre_receptor,\n               u.nombre AS created_by_nombre\n        FROM salidas s\n        LEFT JOIN catalogo_quien_entrega qe ON qe.id = s.quien_entrega_id\n        LEFT JOIN catalogo_plantel pl ON pl.id = s.plantel_id\n        LEFT JOIN catalogo_receptor rec ON rec.id = s.receptor_id\n        LEFT JOIN usuarios u ON u.id = s.created_by\n        WHERE s.estado = 'completada'\n          AND YEAR(s.fecha) = ?\n          AND MONTH(s.fecha) = ?\n        ORDER BY s.fecha ASC, s.id ASC\n    ","params_raw":[2026,3],"resumen":"usuario=Administrador GET /sistema-almacen/inventario.php -> SELECT tabla? params=[2026,3]","ok":true}
{"timestamp":"2026-03-18T19:20:56+01:00","request_id":"ac168eae-3a42-41ed-ace9-29cb89656433","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.198,"op":"SELECT","write":false,"tabla":null,"sql":"\n            SELECT ds.cantidad, p.nombre AS producto_nombre, p.unidad\n            FROM detalle_salidas ds\n            JOIN productos p ON p.id = ds.producto_id\n            WHERE ds.salida_id = ?\n        ","params_raw":[1],"resumen":"usuario=Administrador GET /sistema-almacen/inventario.php -> SELECT tabla? params=[1]","ok":true}
{"timestamp":"2026-03-18T19:20:56+01:00","request_id":"ac168eae-3a42-41ed-ace9-29cb89656433","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.263,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT COALESCE(SUM(de.cantidad), 0) AS total\n        FROM detalle_entradas de\n        JOIN entradas e ON e.id = de.entrada_id\n        WHERE e.estado = 'completada' AND (de.estado = 'activa' OR de.estado IS NULL) AND YEAR(e.fecha) = ? AND MONTH(e.fecha) = ?\n    ","params_raw":[2026,3],"resumen":"usuario=Administrador GET /sistema-almacen/inventario.php -> SELECT tabla? params=[2026,3]","ok":true}
{"timestamp":"2026-03-18T19:20:56+01:00","request_id":"ac168eae-3a42-41ed-ace9-29cb89656433","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.218,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT COALESCE(SUM(ds.cantidad), 0) AS total\n        FROM detalle_salidas ds\n        JOIN salidas s ON s.id = ds.salida_id\n        WHERE s.estado = 'completada' AND YEAR(s.fecha) = ? AND MONTH(s.fecha) = ?\n    ","params_raw":[2026,3],"resumen":"usuario=Administrador GET /sistema-almacen/inventario.php -> SELECT tabla? params=[2026,3]","ok":true}
