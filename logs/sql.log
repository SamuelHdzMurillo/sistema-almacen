{"timestamp":"2026-03-19T18:08:29+01:00","request_id":"e12b324c-b950-465f-897e-83a4c6e35008","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.365,"op":"SELECT","write":false,"tabla":null,"sql":"\n            SELECT ds.cantidad, p.nombre AS producto_nombre, p.unidad\n            FROM detalle_salidas ds\n            JOIN productos p ON p.id = ds.producto_id\n            WHERE ds.salida_id = ?\n        ","params_raw":[1],"resumen":"usuario=Administrador GET /sistema-almacen/inventario.php -> SELECT tabla? params=[1]","ok":true}
{"timestamp":"2026-03-19T18:08:29+01:00","request_id":"e12b324c-b950-465f-897e-83a4c6e35008","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.344,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT COALESCE(SUM(de.cantidad), 0) AS total\n        FROM detalle_entradas de\n        JOIN entradas e ON e.id = de.entrada_id\n        WHERE e.estado = 'completada'\n          AND e.almacen_id = ?\n          AND (de.estado = 'activa' OR de.estado IS NULL)\n          AND YEAR(e.fecha) = ? AND MONTH(e.fecha) = ?\n    ","params_raw":[1,2026,3],"resumen":"usuario=Administrador GET /sistema-almacen/inventario.php -> SELECT tabla? params=[1,2026,3]","ok":true}
{"timestamp":"2026-03-19T18:08:29+01:00","request_id":"e12b324c-b950-465f-897e-83a4c6e35008","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.265,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT COALESCE(SUM(ds.cantidad), 0) AS total\n        FROM detalle_salidas ds\n        JOIN salidas s ON s.id = ds.salida_id\n        WHERE s.estado = 'completada'\n          AND s.almacen_id = ?\n          AND YEAR(s.fecha) = ? AND MONTH(s.fecha) = ?\n    ","params_raw":[1,2026,3],"resumen":"usuario=Administrador GET /sistema-almacen/inventario.php -> SELECT tabla? params=[1,2026,3]","ok":true}
{"timestamp":"2026-03-19T18:08:29+01:00","request_id":"e12b324c-b950-465f-897e-83a4c6e35008","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":1.897,"op":"SELECT","write":false,"tabla":null,"sql":"\r\n        SELECT p.id, p.codigo, p.nombre, p.unidad,\r\n          (SELECT COALESCE(SUM(de.cantidad), 0) FROM detalle_entradas de\r\n           JOIN entradas e ON e.id = de.entrada_id\r\n           WHERE de.producto_id = p.id\r\n             AND e.almacen_id = ?\r\n             AND e.estado != 'cancelada'\r\n             AND (de.estado = 'activa' OR de.estado IS NULL)) -\r\n          (SELECT COALESCE(SUM(ds.cantidad), 0) FROM detalle_salidas ds\r\n           JOIN salidas s ON s.id = ds.salida_id\r\n           WHERE ds.producto_id = p.id\r\n             AND s.almacen_id = ?\r\n             AND s.estado != 'cancelada') AS stock\r\n        FROM productos p\r\n    ","params_raw":[1,1],"resumen":"usuario=Administrador GET /sistema-almacen/inventario.php -> SELECT tabla? params=[1,1]","ok":true}
{"timestamp":"2026-03-19T18:08:29+01:00","request_id":"1b9bac54-1323-4f58-8071-825f7176416b","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":1.124,"op":"SELECT","write":false,"tabla":null,"sql":"\n            SELECT e.id, e.referencia, e.factura, e.fecha, prov.nombre AS persona, e.estado,\n                   'in' AS tipo, de.cantidad, p.nombre AS item_nombre,\n                   e.created_at, e.created_by, u.nombre AS created_by_nombre\n            FROM entradas e\n            LEFT JOIN catalogo_proveedor prov ON prov.id = e.proveedor_id\n            JOIN detalle_entradas de ON de.entrada_id = e.id AND (de.estado = 'activa' OR de.estado IS NULL)\n            JOIN productos p ON p.id = de.producto_id\n            LEFT JOIN usuarios u ON u.id = e.created_by\n            WHERE 1=1 AND e.almacen_id = ?\n         ORDER BY e.created_at DESC, de.id DESC LIMIT 50","params_raw":[1],"resumen":"usuario=Administrador GET /sistema-almacen/transacciones.php -> SELECT tabla? params=[1]","ok":true}
{"timestamp":"2026-03-19T18:08:29+01:00","request_id":"1b9bac54-1323-4f58-8071-825f7176416b","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.572,"op":"SELECT","write":false,"tabla":null,"sql":"\n            SELECT s.id, s.referencia, s.fecha, rec.nombre AS persona, s.estado,\n                   'out' AS tipo, ds.cantidad, p.nombre AS item_nombre,\n                   s.created_at, s.created_by, u.nombre AS created_by_nombre,\n                   qe.nombre AS nombre_entrega, pl.nombre AS plantel_nombre, rec.nombre AS nombre_receptor\n            FROM salidas s\n            LEFT JOIN catalogo_quien_entrega qe ON qe.id = s.quien_entrega_id\n            LEFT JOIN catalogo_plantel pl ON pl.id = s.plantel_id\n            LEFT JOIN catalogo_receptor rec ON rec.id = s.receptor_id\n            JOIN detalle_salidas ds ON ds.salida_id = s.id\n            JOIN productos p ON p.id = ds.producto_id\n            LEFT JOIN usuarios u ON u.id = s.created_by\n            WHERE 1=1 AND s.almacen_id = ?\n         ORDER BY s.created_at DESC, ds.id DESC LIMIT 50","params_raw":[1],"resumen":"usuario=Administrador GET /sistema-almacen/transacciones.php -> SELECT tabla? params=[1]","ok":true}
