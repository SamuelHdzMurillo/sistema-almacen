{"timestamp":"2026-03-20T20:22:31+01:00","request_id":"05f9ef11-7aba-465e-b770-c8575ca87e4d","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":4.457,"op":"INSERT","write":true,"tabla":"detalle_salidas","sql":"INSERT INTO detalle_salidas (salida_id, producto_id, cantidad, created_by) VALUES (?, ?, ?, ?)","params_raw":[3,"33",3000,2],"resumen":"usuario=Arturo POST /sistema-almacen/nueva-salida.php -> INSERT detalle_salidas params=[3,\"33\",3000,2]","ok":true}
{"timestamp":"2026-03-20T20:22:31+01:00","request_id":"630d9adf-23bb-4cee-b5d2-edfa5faca7d9","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":0.526,"op":"SELECT","write":false,"tabla":null,"sql":"\r\n        SELECT s.id, s.referencia, s.fecha, s.estado, s.created_at, s.updated_at, s.created_by,\r\n               s.quien_entrega_id, s.plantel_id, s.receptor_id, s.recibo_entrega_doc,\r\n               qe.nombre AS nombre_entrega, pl.nombre AS plantel_nombre, rec.nombre AS nombre_receptor,\r\n               u.nombre AS created_by_nombre\r\n        FROM salidas s\r\n        LEFT JOIN catalogo_quien_entrega qe ON qe.id = s.quien_entrega_id\r\n        LEFT JOIN catalogo_plantel pl ON pl.id = s.plantel_id\r\n        LEFT JOIN catalogo_receptor rec ON rec.id = s.receptor_id\r\n        LEFT JOIN usuarios u ON u.id = s.created_by\r\n        WHERE s.id = ? AND s.almacen_id = ?\r\n    ","params_raw":[3,2],"resumen":"usuario=Arturo GET /sistema-almacen/recibo.php -> SELECT tabla? params=[3,2]","ok":true}
{"timestamp":"2026-03-20T20:22:31+01:00","request_id":"630d9adf-23bb-4cee-b5d2-edfa5faca7d9","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":0.642,"op":"SELECT","write":false,"tabla":null,"sql":"\r\n        SELECT ds.id, ds.producto_id, ds.cantidad, p.nombre AS producto_nombre, p.unidad\r\n        FROM detalle_salidas ds\r\n        JOIN productos p ON p.id = ds.producto_id\r\n        WHERE ds.salida_id = ?\r\n        ORDER BY ds.id\r\n    ","params_raw":[3],"resumen":"usuario=Arturo GET /sistema-almacen/recibo.php -> SELECT tabla? params=[3]","ok":true}
