{"timestamp":"2026-03-18T19:43:29+01:00","request_id":"7d356d1b-8cb9-4591-b45b-609d3e88903c","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.386,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT COALESCE(SUM(ds.cantidad), 0) AS total\n        FROM detalle_salidas ds\n        JOIN salidas s ON s.id = ds.salida_id\n        WHERE s.estado = 'completada' AND YEAR(s.fecha) = ? AND MONTH(s.fecha) = ?\n    ","params_raw":[2026,3],"resumen":"usuario=Administrador GET /sistema-almacen/inventario.php -> SELECT tabla? params=[2026,3]","ok":true}
{"timestamp":"2026-03-18T19:43:30+01:00","request_id":"b5f273bb-799c-45a8-9bf9-241c107788b5","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":1.11,"op":"SELECT","write":false,"tabla":null,"sql":"\n            SELECT e.id, e.referencia, e.factura, e.fecha, prov.nombre AS persona, e.estado,\n                   'in' AS tipo, de.cantidad, p.nombre AS item_nombre,\n                   e.created_at, e.created_by, u.nombre AS created_by_nombre\n            FROM entradas e\n            LEFT JOIN catalogo_proveedor prov ON prov.id = e.proveedor_id\n            JOIN detalle_entradas de ON de.entrada_id = e.id AND (de.estado = 'activa' OR de.estado IS NULL)\n            JOIN productos p ON p.id = de.producto_id\n            LEFT JOIN usuarios u ON u.id = e.created_by\n            WHERE 1=1\n         ORDER BY e.created_at DESC, de.id DESC LIMIT 50","params_raw":[],"resumen":"usuario=Administrador GET /sistema-almacen/transacciones.php -> SELECT tabla? params=[]","ok":true}
{"timestamp":"2026-03-18T19:43:30+01:00","request_id":"b5f273bb-799c-45a8-9bf9-241c107788b5","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.595,"op":"SELECT","write":false,"tabla":null,"sql":"\n            SELECT s.id, s.referencia, s.fecha, rec.nombre AS persona, s.estado,\n                   'out' AS tipo, ds.cantidad, p.nombre AS item_nombre,\n                   s.created_at, s.created_by, u.nombre AS created_by_nombre,\n                   qe.nombre AS nombre_entrega, pl.nombre AS plantel_nombre, rec.nombre AS nombre_receptor\n            FROM salidas s\n            LEFT JOIN catalogo_quien_entrega qe ON qe.id = s.quien_entrega_id\n            LEFT JOIN catalogo_plantel pl ON pl.id = s.plantel_id\n            LEFT JOIN catalogo_receptor rec ON rec.id = s.receptor_id\n            JOIN detalle_salidas ds ON ds.salida_id = s.id\n            JOIN productos p ON p.id = ds.producto_id\n            LEFT JOIN usuarios u ON u.id = s.created_by\n            WHERE 1=1\n         ORDER BY s.created_at DESC, ds.id DESC LIMIT 50","params_raw":[],"resumen":"usuario=Administrador GET /sistema-almacen/transacciones.php -> SELECT tabla? params=[]","ok":true}
{"timestamp":"2026-03-18T19:43:33+01:00","request_id":"98d0e56e-a486-4b1c-879e-a060ba8f765f","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.352,"op":"SELECT","write":false,"tabla":null,"sql":"\r\n        SELECT s.id, s.referencia, s.fecha, s.estado, s.created_at, s.updated_at, s.created_by,\r\n               qe.nombre AS nombre_entrega, pl.nombre AS plantel_nombre, rec.nombre AS nombre_receptor,\r\n               u.nombre AS created_by_nombre\r\n        FROM salidas s\r\n        LEFT JOIN catalogo_quien_entrega qe ON qe.id = s.quien_entrega_id\r\n        LEFT JOIN catalogo_plantel pl ON pl.id = s.plantel_id\r\n        LEFT JOIN catalogo_receptor rec ON rec.id = s.receptor_id\r\n        LEFT JOIN usuarios u ON u.id = s.created_by\r\n        WHERE s.id = ?\r\n    ","params_raw":[1],"resumen":"usuario=Administrador GET /sistema-almacen/ver-transaccion.php -> SELECT tabla? params=[1]","ok":true}
{"timestamp":"2026-03-18T19:43:33+01:00","request_id":"98d0e56e-a486-4b1c-879e-a060ba8f765f","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.485,"op":"SELECT","write":false,"tabla":null,"sql":"\r\n        SELECT ds.id, ds.producto_id, ds.cantidad, p.nombre AS producto_nombre, p.unidad\r\n        FROM detalle_salidas ds\r\n        JOIN productos p ON p.id = ds.producto_id\r\n        WHERE ds.salida_id = ?\r\n        ORDER BY ds.id\r\n    ","params_raw":[1],"resumen":"usuario=Administrador GET /sistema-almacen/ver-transaccion.php -> SELECT tabla? params=[1]","ok":true}
