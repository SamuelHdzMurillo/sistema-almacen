{"timestamp":"2026-03-19T22:11:12+01:00","request_id":"f2b3ca71-04b3-482f-9d4c-af6ec6d0b4a5","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":0.52,"op":"SELECT","write":false,"tabla":null,"sql":"\r\n        SELECT s.id, s.referencia, s.fecha, s.estado, s.created_at, s.updated_at, s.created_by,\r\n               s.quien_entrega_id, s.plantel_id, s.receptor_id, s.recibo_entrega_doc,\r\n               qe.nombre AS nombre_entrega, pl.nombre AS plantel_nombre, rec.nombre AS nombre_receptor,\r\n               u.nombre AS created_by_nombre\r\n        FROM salidas s\r\n        LEFT JOIN catalogo_quien_entrega qe ON qe.id = s.quien_entrega_id\r\n        LEFT JOIN catalogo_plantel pl ON pl.id = s.plantel_id\r\n        LEFT JOIN catalogo_receptor rec ON rec.id = s.receptor_id\r\n        LEFT JOIN usuarios u ON u.id = s.created_by\r\n        WHERE s.id = ? AND s.almacen_id = ?\r\n    ","params_raw":[2,2],"resumen":"usuario=Arturo GET /sistema-almacen/ver-transaccion.php -> SELECT tabla? params=[2,2]","ok":true}
{"timestamp":"2026-03-19T22:11:12+01:00","request_id":"f2b3ca71-04b3-482f-9d4c-af6ec6d0b4a5","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":0.479,"op":"SELECT","write":false,"tabla":null,"sql":"\r\n        SELECT ds.id, ds.producto_id, ds.cantidad, p.nombre AS producto_nombre, p.unidad\r\n        FROM detalle_salidas ds\r\n        JOIN productos p ON p.id = ds.producto_id\r\n        WHERE ds.salida_id = ?\r\n        ORDER BY ds.id\r\n    ","params_raw":[2],"resumen":"usuario=Arturo GET /sistema-almacen/ver-transaccion.php -> SELECT tabla? params=[2]","ok":true}
{"timestamp":"2026-03-19T22:11:15+01:00","request_id":"b83b0b4e-ee61-4111-b4be-3f8dd7a5b764","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":0.709,"op":"SELECT","write":false,"tabla":null,"sql":"\n            SELECT e.id, e.referencia, e.factura, e.fecha, prov.nombre AS persona, e.estado,\n                   'in' AS tipo, de.cantidad, p.nombre AS item_nombre,\n                   e.created_at, e.created_by, u.nombre AS created_by_nombre\n            FROM entradas e\n            LEFT JOIN catalogo_proveedor prov ON prov.id = e.proveedor_id\n            JOIN detalle_entradas de ON de.entrada_id = e.id AND (de.estado = 'activa' OR de.estado IS NULL)\n            JOIN productos p ON p.id = de.producto_id\n            LEFT JOIN usuarios u ON u.id = e.created_by\n            WHERE 1=1 AND e.almacen_id = ?\n         ORDER BY e.created_at DESC, de.id DESC LIMIT 50","params_raw":[2],"resumen":"usuario=Arturo GET /sistema-almacen/transacciones.php -> SELECT tabla? params=[2]","ok":true}
{"timestamp":"2026-03-19T22:11:15+01:00","request_id":"b83b0b4e-ee61-4111-b4be-3f8dd7a5b764","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":0.948,"op":"SELECT","write":false,"tabla":null,"sql":"\n            SELECT s.id, s.referencia, s.fecha, rec.nombre AS persona, s.estado,\n                   'out' AS tipo, ds.cantidad, p.nombre AS item_nombre,\n                   s.created_at, s.created_by, u.nombre AS created_by_nombre,\n                   qe.nombre AS nombre_entrega, pl.nombre AS plantel_nombre, rec.nombre AS nombre_receptor\n            FROM salidas s\n            LEFT JOIN catalogo_quien_entrega qe ON qe.id = s.quien_entrega_id\n            LEFT JOIN catalogo_plantel pl ON pl.id = s.plantel_id\n            LEFT JOIN catalogo_receptor rec ON rec.id = s.receptor_id\n            JOIN detalle_salidas ds ON ds.salida_id = s.id\n            JOIN productos p ON p.id = ds.producto_id\n            LEFT JOIN usuarios u ON u.id = s.created_by\n            WHERE 1=1 AND s.almacen_id = ?\n         ORDER BY s.created_at DESC, ds.id DESC LIMIT 50","params_raw":[2],"resumen":"usuario=Arturo GET /sistema-almacen/transacciones.php -> SELECT tabla? params=[2]","ok":true}
{"timestamp":"2026-03-19T22:11:32+01:00","request_id":"857e71a6-5b24-4558-b853-90ce919c5b65","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":0.352,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT e.id, e.referencia, e.factura, e.factura_doc, e.fecha, e.estado, e.created_at, e.updated_at, e.created_by,\n               e.proveedor_id, e.quien_recibe_id,\n               u.nombre AS created_by_nombre,\n               prov.nombre AS proveedor_nombre,\n               qr.nombre AS quien_recibe_nombre\n        FROM entradas e\n        LEFT JOIN usuarios u ON u.id = e.created_by\n        LEFT JOIN catalogo_proveedor prov ON prov.id = e.proveedor_id\n        LEFT JOIN catalogo_quien_recibe_entrada qr ON qr.id = e.quien_recibe_id\n        WHERE e.id = ? AND e.almacen_id = ?\n    ","params_raw":[21,2],"resumen":"usuario=Arturo GET /sistema-almacen/ver-transaccion.php -> SELECT tabla? params=[21,2]","ok":true}
{"timestamp":"2026-03-19T22:11:32+01:00","request_id":"857e71a6-5b24-4558-b853-90ce919c5b65","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":0.395,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT de.id, de.producto_id, de.cantidad, COALESCE(de.estado, 'activa') AS estado, p.nombre AS producto_nombre, p.unidad\n        FROM detalle_entradas de\n        JOIN productos p ON p.id = de.producto_id\n        WHERE de.entrada_id = ?\n        ORDER BY de.id\n    ","params_raw":[21],"resumen":"usuario=Arturo GET /sistema-almacen/ver-transaccion.php -> SELECT tabla? params=[21]","ok":true}
{"timestamp":"2026-03-19T22:11:34+01:00","request_id":"0ac32dbd-d614-4f2a-9f3b-c2efabdfdebb","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":0.499,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT e.id, e.referencia, e.factura, e.factura_doc, e.fecha, e.estado, e.created_at, e.updated_at, e.created_by,\n               e.proveedor_id, e.quien_recibe_id,\n               u.nombre AS created_by_nombre,\n               prov.nombre AS proveedor_nombre,\n               qr.nombre AS quien_recibe_nombre\n        FROM entradas e\n        LEFT JOIN usuarios u ON u.id = e.created_by\n        LEFT JOIN catalogo_proveedor prov ON prov.id = e.proveedor_id\n        LEFT JOIN catalogo_quien_recibe_entrada qr ON qr.id = e.quien_recibe_id\n        WHERE e.id = ? AND e.almacen_id = ?\n    ","params_raw":[21,2],"resumen":"usuario=Arturo GET /sistema-almacen/recibo-entrada.php -> SELECT tabla? params=[21,2]","ok":true}
{"timestamp":"2026-03-19T22:11:34+01:00","request_id":"0ac32dbd-d614-4f2a-9f3b-c2efabdfdebb","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":0.434,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT de.id, de.producto_id, de.cantidad, COALESCE(de.estado, 'activa') AS estado, p.nombre AS producto_nombre, p.unidad\n        FROM detalle_entradas de\n        JOIN productos p ON p.id = de.producto_id\n        WHERE de.entrada_id = ?\n        ORDER BY de.id\n    ","params_raw":[21],"resumen":"usuario=Arturo GET /sistema-almacen/recibo-entrada.php -> SELECT tabla? params=[21]","ok":true}
