{"timestamp":"2026-03-19T20:03:38+01:00","request_id":"c958d553-4623-46da-92bf-4de924d582b0","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.365,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT e.id, e.referencia, e.fecha, e.estado, e.created_at,\n               u.nombre AS created_by_nombre,\n               prov.nombre AS proveedor_nombre, qr.nombre AS quien_recibe_nombre\n        FROM entradas e\n        LEFT JOIN usuarios u ON u.id = e.created_by\n        LEFT JOIN catalogo_proveedor prov ON prov.id = e.proveedor_id\n        LEFT JOIN catalogo_quien_recibe_entrada qr ON qr.id = e.quien_recibe_id\n        WHERE e.estado = 'completada'\n          AND e.almacen_id = ?\n          AND YEAR(e.fecha) = ?\n          AND MONTH(e.fecha) = ?\n        ORDER BY e.fecha ASC, e.id ASC\n    ","params_raw":[2,2026,3],"resumen":"usuario=Administrador GET /sistema-almacen/inventario.php -> SELECT tabla? params=[2,2026,3]","ok":true}
{"timestamp":"2026-03-19T20:03:38+01:00","request_id":"c958d553-4623-46da-92bf-4de924d582b0","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.266,"op":"SELECT","write":false,"tabla":null,"sql":"\n            SELECT de.cantidad, p.nombre AS producto_nombre, p.unidad\n            FROM detalle_entradas de\n            JOIN productos p ON p.id = de.producto_id\n            WHERE de.entrada_id = ? AND (de.estado = 'activa' OR de.estado IS NULL)\n        ","params_raw":[21],"resumen":"usuario=Administrador GET /sistema-almacen/inventario.php -> SELECT tabla? params=[21]","ok":true}
{"timestamp":"2026-03-19T20:03:38+01:00","request_id":"c958d553-4623-46da-92bf-4de924d582b0","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.156,"op":"SELECT","write":false,"tabla":null,"sql":"SELECT id FROM almacenes WHERE id = ? LIMIT 1","params_raw":[2],"resumen":"usuario=Administrador GET /sistema-almacen/inventario.php -> SELECT tabla? params=[2]","ok":true}
{"timestamp":"2026-03-19T20:03:38+01:00","request_id":"c958d553-4623-46da-92bf-4de924d582b0","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.347,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT s.id, s.referencia, s.fecha, s.estado, s.created_at,\n               qe.nombre AS nombre_entrega, pl.nombre AS plantel_nombre, rec.nombre AS nombre_receptor,\n               u.nombre AS created_by_nombre\n        FROM salidas s\n        LEFT JOIN catalogo_quien_entrega qe ON qe.id = s.quien_entrega_id\n        LEFT JOIN catalogo_plantel pl ON pl.id = s.plantel_id\n        LEFT JOIN catalogo_receptor rec ON rec.id = s.receptor_id\n        LEFT JOIN usuarios u ON u.id = s.created_by\n        WHERE s.estado = 'completada'\n          AND s.almacen_id = ?\n          AND YEAR(s.fecha) = ?\n          AND MONTH(s.fecha) = ?\n        ORDER BY s.fecha ASC, s.id ASC\n    ","params_raw":[2,2026,3],"resumen":"usuario=Administrador GET /sistema-almacen/inventario.php -> SELECT tabla? params=[2,2026,3]","ok":true}
{"timestamp":"2026-03-19T20:03:38+01:00","request_id":"c958d553-4623-46da-92bf-4de924d582b0","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.212,"op":"SELECT","write":false,"tabla":null,"sql":"SELECT id FROM almacenes WHERE id = ? LIMIT 1","params_raw":[2],"resumen":"usuario=Administrador GET /sistema-almacen/inventario.php -> SELECT tabla? params=[2]","ok":true}
{"timestamp":"2026-03-19T20:03:38+01:00","request_id":"c958d553-4623-46da-92bf-4de924d582b0","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.415,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT COALESCE(SUM(de.cantidad), 0) AS total\n        FROM detalle_entradas de\n        JOIN entradas e ON e.id = de.entrada_id\n        WHERE e.estado = 'completada'\n          AND e.almacen_id = ?\n          AND (de.estado = 'activa' OR de.estado IS NULL)\n          AND YEAR(e.fecha) = ? AND MONTH(e.fecha) = ?\n    ","params_raw":[2,2026,3],"resumen":"usuario=Administrador GET /sistema-almacen/inventario.php -> SELECT tabla? params=[2,2026,3]","ok":true}
{"timestamp":"2026-03-19T20:03:38+01:00","request_id":"c958d553-4623-46da-92bf-4de924d582b0","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.367,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT COALESCE(SUM(ds.cantidad), 0) AS total\n        FROM detalle_salidas ds\n        JOIN salidas s ON s.id = ds.salida_id\n        WHERE s.estado = 'completada'\n          AND s.almacen_id = ?\n          AND YEAR(s.fecha) = ? AND MONTH(s.fecha) = ?\n    ","params_raw":[2,2026,3],"resumen":"usuario=Administrador GET /sistema-almacen/inventario.php -> SELECT tabla? params=[2,2026,3]","ok":true}
