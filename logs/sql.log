{"timestamp":"2026-03-20T20:22:31+01:00","request_id":"05f9ef11-7aba-465e-b770-c8575ca87e4d","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":2.517,"op":"SELECT","write":false,"tabla":null,"sql":"\r\n        SELECT p.id, p.codigo, p.nombre, p.unidad,\r\n          (SELECT COALESCE(SUM(de.cantidad), 0) FROM detalle_entradas de\r\n           JOIN entradas e ON e.id = de.entrada_id\r\n           WHERE de.producto_id = p.id\r\n             AND e.almacen_id = ?\r\n             AND e.estado != 'cancelada'\r\n             AND (de.estado = 'activa' OR de.estado IS NULL)) -\r\n          (SELECT COALESCE(SUM(ds.cantidad), 0) FROM detalle_salidas ds\r\n           JOIN salidas s ON s.id = ds.salida_id\r\n           WHERE ds.producto_id = p.id\r\n             AND s.almacen_id = ?\r\n             AND s.estado != 'cancelada') AS stock\r\n        FROM productos p\r\n    ","params_raw":[2,2],"resumen":"usuario=Arturo POST /sistema-almacen/nueva-salida.php -> SELECT tabla? params=[2,2]","ok":true}
{"timestamp":"2026-03-20T20:22:31+01:00","request_id":"05f9ef11-7aba-465e-b770-c8575ca87e4d","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":0.34,"op":"SELECT","write":false,"tabla":null,"sql":"SELECT COUNT(*) AS n FROM salidas WHERE referencia LIKE ?","params_raw":["PS-2026-%"],"resumen":"usuario=Arturo POST /sistema-almacen/nueva-salida.php -> SELECT tabla? params=[\"PS-2026-%\"]","ok":true}
