{"timestamp":"2026-03-19T20:40:46+01:00","request_id":"96310494-d52f-4900-97e9-635deca6cb9a","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.577,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT e.id, e.referencia, e.factura, e.factura_doc, e.fecha, e.estado,\n               e.created_at, e.created_by,\n               u.nombre   AS created_by_nombre,\n               prov.nombre AS proveedor_nombre,\n               qr.nombre   AS quien_recibe_nombre\n        FROM entradas e\n        LEFT JOIN usuarios u ON u.id = e.created_by\n        LEFT JOIN catalogo_proveedor prov ON prov.id = e.proveedor_id\n        LEFT JOIN catalogo_quien_recibe_entrada qr ON qr.id = e.quien_recibe_id\n        WHERE e.almacen_id = ? AND e.factura_doc IS NOT NULL AND e.factura_doc != ''\n        ORDER BY e.fecha DESC, e.id DESC\n        LIMIT 200\n    ","params_raw":[1],"resumen":"usuario=Administrador GET /sistema-almacen/facturas.php -> SELECT tabla? params=[1]","ok":true}
{"timestamp":"2026-03-19T20:40:50+01:00","request_id":"e46c338a-e8a2-4e53-9e56-e0396676ec6c","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.503,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT e.id, e.referencia, e.factura, e.factura_doc, e.fecha, e.estado, e.created_at, e.updated_at, e.created_by,\n               e.proveedor_id, e.quien_recibe_id,\n               u.nombre AS created_by_nombre,\n               prov.nombre AS proveedor_nombre,\n               qr.nombre AS quien_recibe_nombre\n        FROM entradas e\n        LEFT JOIN usuarios u ON u.id = e.created_by\n        LEFT JOIN catalogo_proveedor prov ON prov.id = e.proveedor_id\n        LEFT JOIN catalogo_quien_recibe_entrada qr ON qr.id = e.quien_recibe_id\n        WHERE e.id = ? AND e.almacen_id = ?\n    ","params_raw":[23,1],"resumen":"usuario=Administrador GET /sistema-almacen/ver-transaccion.php -> SELECT tabla? params=[23,1]","ok":true}
