{"timestamp":"2026-03-20T20:19:58+01:00","request_id":"1c70cb74-099e-44ca-a8b1-427c5a0099cc","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":0.601,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT e.id, e.referencia, e.factura, e.factura_doc, e.fecha, e.estado, e.created_at, e.updated_at, e.created_by,\n               e.proveedor_id, e.quien_recibe_id,\n               u.nombre AS created_by_nombre,\n               prov.nombre AS proveedor_nombre,\n               qr.nombre AS quien_recibe_nombre\n        FROM entradas e\n        LEFT JOIN usuarios u ON u.id = e.created_by\n        LEFT JOIN catalogo_proveedor prov ON prov.id = e.proveedor_id\n        LEFT JOIN catalogo_quien_recibe_entrada qr ON qr.id = e.quien_recibe_id\n        WHERE e.id = ? AND e.almacen_id = ?\n    ","params_raw":[26,2],"resumen":"usuario=Arturo GET /sistema-almacen/recibo-entrada.php -> SELECT tabla? params=[26,2]","ok":true}
{"timestamp":"2026-03-20T20:19:58+01:00","request_id":"1c70cb74-099e-44ca-a8b1-427c5a0099cc","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":0.455,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT de.id, de.producto_id, de.cantidad, COALESCE(de.estado, 'activa') AS estado, p.nombre AS producto_nombre, p.unidad\n        FROM detalle_entradas de\n        JOIN productos p ON p.id = de.producto_id\n        WHERE de.entrada_id = ?\n        ORDER BY de.id\n    ","params_raw":[26],"resumen":"usuario=Arturo GET /sistema-almacen/recibo-entrada.php -> SELECT tabla? params=[26]","ok":true}
{"timestamp":"2026-03-20T20:20:03+01:00","request_id":"1e5a2ac5-1ec2-4da7-94b9-0047f1c2b1a8","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":0.66,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT e.id, e.referencia, e.factura, e.factura_doc, e.fecha, e.estado, e.created_at, e.updated_at, e.created_by,\n               e.proveedor_id, e.quien_recibe_id,\n               u.nombre AS created_by_nombre,\n               prov.nombre AS proveedor_nombre,\n               qr.nombre AS quien_recibe_nombre\n        FROM entradas e\n        LEFT JOIN usuarios u ON u.id = e.created_by\n        LEFT JOIN catalogo_proveedor prov ON prov.id = e.proveedor_id\n        LEFT JOIN catalogo_quien_recibe_entrada qr ON qr.id = e.quien_recibe_id\n        WHERE e.id = ? AND e.almacen_id = ?\n    ","params_raw":[26,2],"resumen":"usuario=Arturo GET /sistema-almacen/recibo-entrada.php -> SELECT tabla? params=[26,2]","ok":true}
{"timestamp":"2026-03-20T20:20:03+01:00","request_id":"1e5a2ac5-1ec2-4da7-94b9-0047f1c2b1a8","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":0.699,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT de.id, de.producto_id, de.cantidad, COALESCE(de.estado, 'activa') AS estado, p.nombre AS producto_nombre, p.unidad\n        FROM detalle_entradas de\n        JOIN productos p ON p.id = de.producto_id\n        WHERE de.entrada_id = ?\n        ORDER BY de.id\n    ","params_raw":[26],"resumen":"usuario=Arturo GET /sistema-almacen/recibo-entrada.php -> SELECT tabla? params=[26]","ok":true}
{"timestamp":"2026-03-20T20:20:30+01:00","request_id":"6b7417df-8d31-4ef3-a5cd-fb30efef30b4","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":0.577,"op":"SELECT","write":false,"tabla":null,"sql":"\n            SELECT e.id, e.referencia, e.factura, e.fecha, prov.nombre AS persona, e.estado,\n                   'in' AS tipo, de.cantidad, p.nombre AS item_nombre,\n                   e.created_at, e.created_by, u.nombre AS created_by_nombre\n            FROM entradas e\n            LEFT JOIN catalogo_proveedor prov ON prov.id = e.proveedor_id\n            JOIN detalle_entradas de ON de.entrada_id = e.id AND (de.estado = 'activa' OR de.estado IS NULL)\n            JOIN productos p ON p.id = de.producto_id\n            LEFT JOIN usuarios u ON u.id = e.created_by\n            WHERE 1=1 AND e.almacen_id = ?\n         ORDER BY e.created_at DESC, de.id DESC LIMIT 50","params_raw":[2],"resumen":"usuario=Arturo GET /sistema-almacen/transacciones.php -> SELECT tabla? params=[2]","ok":true}
{"timestamp":"2026-03-20T20:20:30+01:00","request_id":"6b7417df-8d31-4ef3-a5cd-fb30efef30b4","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":0.671,"op":"SELECT","write":false,"tabla":null,"sql":"\n            SELECT s.id, s.referencia, s.fecha, rec.nombre AS persona, s.estado,\n                   'out' AS tipo, ds.cantidad, p.nombre AS item_nombre,\n                   s.created_at, s.created_by, u.nombre AS created_by_nombre,\n                   qe.nombre AS nombre_entrega, pl.nombre AS plantel_nombre, rec.nombre AS nombre_receptor\n            FROM salidas s\n            LEFT JOIN catalogo_quien_entrega qe ON qe.id = s.quien_entrega_id\n            LEFT JOIN catalogo_plantel pl ON pl.id = s.plantel_id\n            LEFT JOIN catalogo_receptor rec ON rec.id = s.receptor_id\n            JOIN detalle_salidas ds ON ds.salida_id = s.id\n            JOIN productos p ON p.id = ds.producto_id\n            LEFT JOIN usuarios u ON u.id = s.created_by\n            WHERE 1=1 AND s.almacen_id = ?\n         ORDER BY s.created_at DESC, ds.id DESC LIMIT 50","params_raw":[2],"resumen":"usuario=Arturo GET /sistema-almacen/transacciones.php -> SELECT tabla? params=[2]","ok":true}
{"timestamp":"2026-03-20T20:20:30+01:00","request_id":"6b7417df-8d31-4ef3-a5cd-fb30efef30b4","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":0.353,"op":"SELECT","write":false,"tabla":null,"sql":"SELECT nombre FROM almacenes WHERE id = ? LIMIT 1","params_raw":[2],"resumen":"usuario=Arturo GET /sistema-almacen/transacciones.php -> SELECT tabla? params=[2]","ok":true}
