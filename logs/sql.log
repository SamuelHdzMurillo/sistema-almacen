{"timestamp":"2026-03-18T22:23:16+01:00","request_id":"3ebc2508-dd1b-4485-9215-382e888ac87f","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.897,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT s.id, s.referencia, s.fecha, s.estado, s.created_at,\n               qe.nombre AS nombre_entrega, pl.nombre AS plantel_nombre, rec.nombre AS nombre_receptor,\n               u.nombre AS created_by_nombre\n        FROM salidas s\n        LEFT JOIN catalogo_quien_entrega qe ON qe.id = s.quien_entrega_id\n        LEFT JOIN catalogo_plantel pl ON pl.id = s.plantel_id\n        LEFT JOIN catalogo_receptor rec ON rec.id = s.receptor_id\n        LEFT JOIN usuarios u ON u.id = s.created_by\n        WHERE s.estado = 'completada'\n          AND YEAR(s.fecha) = ?\n          AND MONTH(s.fecha) = ?\n        ORDER BY s.fecha ASC, s.id ASC\n    ","params_raw":[2026,3],"resumen":"usuario=Administrador GET /sistema-almacen/inventario.php -> SELECT tabla? params=[2026,3]","ok":true}
{"timestamp":"2026-03-18T22:23:16+01:00","request_id":"3ebc2508-dd1b-4485-9215-382e888ac87f","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.883,"op":"SELECT","write":false,"tabla":null,"sql":"\n            SELECT ds.cantidad, p.nombre AS producto_nombre, p.unidad\n            FROM detalle_salidas ds\n            JOIN productos p ON p.id = ds.producto_id\n            WHERE ds.salida_id = ?\n        ","params_raw":[1],"resumen":"usuario=Administrador GET /sistema-almacen/inventario.php -> SELECT tabla? params=[1]","ok":true}
{"timestamp":"2026-03-18T22:23:16+01:00","request_id":"3ebc2508-dd1b-4485-9215-382e888ac87f","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.523,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT COALESCE(SUM(de.cantidad), 0) AS total\n        FROM detalle_entradas de\n        JOIN entradas e ON e.id = de.entrada_id\n        WHERE e.estado = 'completada' AND (de.estado = 'activa' OR de.estado IS NULL) AND YEAR(e.fecha) = ? AND MONTH(e.fecha) = ?\n    ","params_raw":[2026,3],"resumen":"usuario=Administrador GET /sistema-almacen/inventario.php -> SELECT tabla? params=[2026,3]","ok":true}
{"timestamp":"2026-03-18T22:23:16+01:00","request_id":"3ebc2508-dd1b-4485-9215-382e888ac87f","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.436,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT COALESCE(SUM(ds.cantidad), 0) AS total\n        FROM detalle_salidas ds\n        JOIN salidas s ON s.id = ds.salida_id\n        WHERE s.estado = 'completada' AND YEAR(s.fecha) = ? AND MONTH(s.fecha) = ?\n    ","params_raw":[2026,3],"resumen":"usuario=Administrador GET /sistema-almacen/inventario.php -> SELECT tabla? params=[2026,3]","ok":true}
{"timestamp":"2026-03-18T22:25:23+01:00","request_id":"0e99f42f-4504-4030-957d-651442420ede","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.95,"op":"SELECT","write":false,"tabla":null,"sql":"\n            SELECT e.id, e.referencia, e.factura, e.fecha, prov.nombre AS persona, e.estado,\n                   'in' AS tipo, de.cantidad, p.nombre AS item_nombre,\n                   e.created_at, e.created_by, u.nombre AS created_by_nombre\n            FROM entradas e\n            LEFT JOIN catalogo_proveedor prov ON prov.id = e.proveedor_id\n            JOIN detalle_entradas de ON de.entrada_id = e.id AND (de.estado = 'activa' OR de.estado IS NULL)\n            JOIN productos p ON p.id = de.producto_id\n            LEFT JOIN usuarios u ON u.id = e.created_by\n            WHERE 1=1\n         ORDER BY e.created_at DESC, de.id DESC LIMIT 50","params_raw":[],"resumen":"usuario=Administrador GET /sistema-almacen/transacciones.php -> SELECT tabla? params=[]","ok":true}
{"timestamp":"2026-03-18T22:25:23+01:00","request_id":"0e99f42f-4504-4030-957d-651442420ede","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.532,"op":"SELECT","write":false,"tabla":null,"sql":"\n            SELECT s.id, s.referencia, s.fecha, rec.nombre AS persona, s.estado,\n                   'out' AS tipo, ds.cantidad, p.nombre AS item_nombre,\n                   s.created_at, s.created_by, u.nombre AS created_by_nombre,\n                   qe.nombre AS nombre_entrega, pl.nombre AS plantel_nombre, rec.nombre AS nombre_receptor\n            FROM salidas s\n            LEFT JOIN catalogo_quien_entrega qe ON qe.id = s.quien_entrega_id\n            LEFT JOIN catalogo_plantel pl ON pl.id = s.plantel_id\n            LEFT JOIN catalogo_receptor rec ON rec.id = s.receptor_id\n            JOIN detalle_salidas ds ON ds.salida_id = s.id\n            JOIN productos p ON p.id = ds.producto_id\n            LEFT JOIN usuarios u ON u.id = s.created_by\n            WHERE 1=1\n         ORDER BY s.created_at DESC, ds.id DESC LIMIT 50","params_raw":[],"resumen":"usuario=Administrador GET /sistema-almacen/transacciones.php -> SELECT tabla? params=[]","ok":true}
