{"timestamp":"2026-03-19T22:03:07+01:00","request_id":"a874dd9c-3cbf-471a-9e16-30b40ec7aecf","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":2.456,"op":"SELECT","write":false,"tabla":null,"sql":"\r\n        SELECT p.id, p.codigo, p.nombre, p.unidad,\r\n          (SELECT COALESCE(SUM(de.cantidad), 0) FROM detalle_entradas de\r\n           JOIN entradas e ON e.id = de.entrada_id\r\n           WHERE de.producto_id = p.id\r\n             AND e.almacen_id = ?\r\n             AND e.estado != 'cancelada'\r\n             AND (de.estado = 'activa' OR de.estado IS NULL)) -\r\n          (SELECT COALESCE(SUM(ds.cantidad), 0) FROM detalle_salidas ds\r\n           JOIN salidas s ON s.id = ds.salida_id\r\n           WHERE ds.producto_id = p.id\r\n             AND s.almacen_id = ?\r\n             AND s.estado != 'cancelada') AS stock\r\n        FROM productos p\r\n    ","params_raw":[2,2],"resumen":"usuario=Arturo GET /sistema-almacen/productos.php -> SELECT tabla? params=[2,2]","ok":true}
{"timestamp":"2026-03-19T22:03:07+01:00","request_id":"d5f3d95f-2bc6-40a8-b1fd-9058f9c8dba6","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":0.617,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT e.id, e.referencia, e.factura, e.factura_doc, e.fecha, e.estado,\n               e.created_at, e.created_by,\n               u.nombre   AS created_by_nombre,\n               prov.nombre AS proveedor_nombre,\n               qr.nombre   AS quien_recibe_nombre\n        FROM entradas e\n        LEFT JOIN usuarios u ON u.id = e.created_by\n        LEFT JOIN catalogo_proveedor prov ON prov.id = e.proveedor_id\n        LEFT JOIN catalogo_quien_recibe_entrada qr ON qr.id = e.quien_recibe_id\n        WHERE e.almacen_id = ? AND e.factura_doc IS NOT NULL AND e.factura_doc != ''\n        ORDER BY e.fecha DESC, e.id DESC\n        LIMIT 200\n    ","params_raw":[2],"resumen":"usuario=Arturo GET /sistema-almacen/facturas.php -> SELECT tabla? params=[2]","ok":true}
{"timestamp":"2026-03-19T22:03:08+01:00","request_id":"75f7e945-474b-44d9-b90c-0288d786b821","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":0.393,"op":"SELECT","write":false,"tabla":null,"sql":"\r\n        SELECT s.id, s.referencia, s.fecha, s.estado, s.created_at,\r\n               qe.nombre AS nombre_entrega, pl.nombre AS plantel_nombre, rec.nombre AS nombre_receptor,\r\n               u.nombre AS created_by_nombre\r\n        FROM salidas s\r\n        LEFT JOIN catalogo_quien_entrega qe ON qe.id = s.quien_entrega_id\r\n        LEFT JOIN catalogo_plantel pl ON pl.id = s.plantel_id\r\n        LEFT JOIN catalogo_receptor rec ON rec.id = s.receptor_id\r\n        LEFT JOIN usuarios u ON u.id = s.created_by\r\n        WHERE s.almacen_id = ?\r\n          AND (s.recibo_entrega_doc IS NULL OR s.recibo_entrega_doc = '')\r\n          AND s.estado != 'cancelada'\r\n        ORDER BY s.fecha DESC, s.created_at DESC\r\n    ","params_raw":[2],"resumen":"usuario=Arturo GET /sistema-almacen/recibos.php -> SELECT tabla? params=[2]","ok":true}
