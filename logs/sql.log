{"timestamp":"2026-03-18T21:32:37+01:00","request_id":"cb04e51d-1a83-4ceb-bec0-7636efa84ad3","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.633,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT COALESCE(SUM(de.cantidad), 0) AS total\n        FROM detalle_entradas de\n        JOIN entradas e ON e.id = de.entrada_id\n        WHERE e.estado = 'completada' AND (de.estado = 'activa' OR de.estado IS NULL) AND YEAR(e.fecha) = ? AND MONTH(e.fecha) = ?\n    ","params_raw":[2026,3],"resumen":"usuario=Administrador GET /sistema-almacen/inventario.php -> SELECT tabla? params=[2026,3]","ok":true}
{"timestamp":"2026-03-18T21:32:37+01:00","request_id":"cb04e51d-1a83-4ceb-bec0-7636efa84ad3","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.755,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT COALESCE(SUM(ds.cantidad), 0) AS total\n        FROM detalle_salidas ds\n        JOIN salidas s ON s.id = ds.salida_id\n        WHERE s.estado = 'completada' AND YEAR(s.fecha) = ? AND MONTH(s.fecha) = ?\n    ","params_raw":[2026,3],"resumen":"usuario=Administrador GET /sistema-almacen/inventario.php -> SELECT tabla? params=[2026,3]","ok":true}
{"timestamp":"2026-03-18T21:32:39+01:00","request_id":"bc0b53c0-671c-401d-9def-1f1d905215f1","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.921,"op":"SELECT","write":false,"tabla":null,"sql":"\n            SELECT e.id, e.referencia, e.factura, e.fecha, prov.nombre AS persona, e.estado,\n                   'in' AS tipo, de.cantidad, p.nombre AS item_nombre,\n                   e.created_at, e.created_by, u.nombre AS created_by_nombre\n            FROM entradas e\n            LEFT JOIN catalogo_proveedor prov ON prov.id = e.proveedor_id\n            JOIN detalle_entradas de ON de.entrada_id = e.id AND (de.estado = 'activa' OR de.estado IS NULL)\n            JOIN productos p ON p.id = de.producto_id\n            LEFT JOIN usuarios u ON u.id = e.created_by\n            WHERE 1=1\n         ORDER BY e.created_at DESC, de.id DESC LIMIT 50","params_raw":[],"resumen":"usuario=Administrador GET /sistema-almacen/transacciones.php -> SELECT tabla? params=[]","ok":true}
{"timestamp":"2026-03-18T21:32:39+01:00","request_id":"bc0b53c0-671c-401d-9def-1f1d905215f1","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.533,"op":"SELECT","write":false,"tabla":null,"sql":"\n            SELECT s.id, s.referencia, s.fecha, rec.nombre AS persona, s.estado,\n                   'out' AS tipo, ds.cantidad, p.nombre AS item_nombre,\n                   s.created_at, s.created_by, u.nombre AS created_by_nombre,\n                   qe.nombre AS nombre_entrega, pl.nombre AS plantel_nombre, rec.nombre AS nombre_receptor\n            FROM salidas s\n            LEFT JOIN catalogo_quien_entrega qe ON qe.id = s.quien_entrega_id\n            LEFT JOIN catalogo_plantel pl ON pl.id = s.plantel_id\n            LEFT JOIN catalogo_receptor rec ON rec.id = s.receptor_id\n            JOIN detalle_salidas ds ON ds.salida_id = s.id\n            JOIN productos p ON p.id = ds.producto_id\n            LEFT JOIN usuarios u ON u.id = s.created_by\n            WHERE 1=1\n         ORDER BY s.created_at DESC, ds.id DESC LIMIT 50","params_raw":[],"resumen":"usuario=Administrador GET /sistema-almacen/transacciones.php -> SELECT tabla? params=[]","ok":true}
{"timestamp":"2026-03-18T21:32:41+01:00","request_id":"6ab09bff-ffa0-4bd4-ae62-5e2bf7b1deab","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.321,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT e.id, e.referencia, e.factura, e.fecha, e.estado, e.created_at, e.updated_at, e.created_by,\n               e.proveedor_id, e.quien_recibe_id,\n               u.nombre AS created_by_nombre,\n               prov.nombre AS proveedor_nombre,\n               qr.nombre AS quien_recibe_nombre\n        FROM entradas e\n        LEFT JOIN usuarios u ON u.id = e.created_by\n        LEFT JOIN catalogo_proveedor prov ON prov.id = e.proveedor_id\n        LEFT JOIN catalogo_quien_recibe_entrada qr ON qr.id = e.quien_recibe_id\n        WHERE e.id = ?\n    ","params_raw":[19],"resumen":"usuario=Administrador GET /sistema-almacen/ver-transaccion.php -> SELECT tabla? params=[19]","ok":true}
