{"timestamp":"2026-03-19T20:30:21+01:00","request_id":"a09ffbaa-e333-4b86-8426-899a732210c3","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.411,"op":"INSERT","write":true,"tabla":"detalle_entradas","sql":"INSERT INTO detalle_entradas (entrada_id, producto_id, cantidad, created_by) VALUES (?, ?, ?, ?)","params_raw":[23,67,133,1],"resumen":"usuario=Administrador POST /sistema-almacen/nueva-entrada.php -> INSERT detalle_entradas params=[23,67,133,1]","ok":true}
{"timestamp":"2026-03-19T20:30:21+01:00","request_id":"4e2e0957-e62c-4ea2-8d12-ebb899145e46","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.567,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT e.id, e.referencia, e.factura, e.factura_doc, e.fecha, e.estado, e.created_at, e.updated_at, e.created_by,\n               e.proveedor_id, e.quien_recibe_id,\n               u.nombre AS created_by_nombre,\n               prov.nombre AS proveedor_nombre,\n               qr.nombre AS quien_recibe_nombre\n        FROM entradas e\n        LEFT JOIN usuarios u ON u.id = e.created_by\n        LEFT JOIN catalogo_proveedor prov ON prov.id = e.proveedor_id\n        LEFT JOIN catalogo_quien_recibe_entrada qr ON qr.id = e.quien_recibe_id\n        WHERE e.id = ? AND e.almacen_id = ?\n    ","params_raw":[23,1],"resumen":"usuario=Administrador GET /sistema-almacen/recibo-entrada.php -> SELECT tabla? params=[23,1]","ok":true}
{"timestamp":"2026-03-19T20:30:21+01:00","request_id":"4e2e0957-e62c-4ea2-8d12-ebb899145e46","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":0.427,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT de.id, de.producto_id, de.cantidad, COALESCE(de.estado, 'activa') AS estado, p.nombre AS producto_nombre, p.unidad\n        FROM detalle_entradas de\n        JOIN productos p ON p.id = de.producto_id\n        WHERE de.entrada_id = ?\n        ORDER BY de.id\n    ","params_raw":[23],"resumen":"usuario=Administrador GET /sistema-almacen/recibo-entrada.php -> SELECT tabla? params=[23]","ok":true}
{"timestamp":"2026-03-19T20:31:49+01:00","request_id":"e1aa8615-a2a8-4f8b-83fd-6aeed0fedebc","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":6.006,"op":"SELECT","write":false,"tabla":null,"sql":"\n            SELECT e.id, e.referencia, e.factura, e.fecha, prov.nombre AS persona, e.estado,\n                   'in' AS tipo, de.cantidad, p.nombre AS item_nombre,\n                   e.created_at, e.created_by, u.nombre AS created_by_nombre\n            FROM entradas e\n            LEFT JOIN catalogo_proveedor prov ON prov.id = e.proveedor_id\n            JOIN detalle_entradas de ON de.entrada_id = e.id AND (de.estado = 'activa' OR de.estado IS NULL)\n            JOIN productos p ON p.id = de.producto_id\n            LEFT JOIN usuarios u ON u.id = e.created_by\n            WHERE 1=1 AND e.almacen_id = ?\n         ORDER BY e.created_at DESC, de.id DESC LIMIT 50","params_raw":[1],"resumen":"usuario=Administrador GET /sistema-almacen/transacciones.php -> SELECT tabla? params=[1]","ok":true}
{"timestamp":"2026-03-19T20:31:49+01:00","request_id":"e1aa8615-a2a8-4f8b-83fd-6aeed0fedebc","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":2.472,"op":"SELECT","write":false,"tabla":null,"sql":"\n            SELECT s.id, s.referencia, s.fecha, rec.nombre AS persona, s.estado,\n                   'out' AS tipo, ds.cantidad, p.nombre AS item_nombre,\n                   s.created_at, s.created_by, u.nombre AS created_by_nombre,\n                   qe.nombre AS nombre_entrega, pl.nombre AS plantel_nombre, rec.nombre AS nombre_receptor\n            FROM salidas s\n            LEFT JOIN catalogo_quien_entrega qe ON qe.id = s.quien_entrega_id\n            LEFT JOIN catalogo_plantel pl ON pl.id = s.plantel_id\n            LEFT JOIN catalogo_receptor rec ON rec.id = s.receptor_id\n            JOIN detalle_salidas ds ON ds.salida_id = s.id\n            JOIN productos p ON p.id = ds.producto_id\n            LEFT JOIN usuarios u ON u.id = s.created_by\n            WHERE 1=1 AND s.almacen_id = ?\n         ORDER BY s.created_at DESC, ds.id DESC LIMIT 50","params_raw":[1],"resumen":"usuario=Administrador GET /sistema-almacen/transacciones.php -> SELECT tabla? params=[1]","ok":true}
{"timestamp":"2026-03-19T20:31:50+01:00","request_id":"ca06538c-a113-4d8f-81b7-6d0266b5a4f8","usuario_id":1,"usuario_nombre":"Administrador","duration_ms":1.891,"op":"SELECT","write":false,"tabla":null,"sql":"\n        SELECT e.id, e.referencia, e.fecha, e.estado, e.created_at,\n               u.nombre AS created_by_nombre,\n               prov.nombre AS proveedor_nombre, qr.nombre AS quien_recibe_nombre\n        FROM entradas e\n        LEFT JOIN usuarios u ON u.id = e.created_by\n        LEFT JOIN catalogo_proveedor prov ON prov.id = e.proveedor_id\n        LEFT JOIN catalogo_quien_recibe_entrada qr ON qr.id = e.quien_recibe_id\n        WHERE e.estado = 'completada'\n          AND e.almacen_id = ?\n          AND YEAR(e.fecha) = ?\n          AND MONTH(e.fecha) = ?\n        ORDER BY e.fecha ASC, e.id ASC\n    ","params_raw":[1,2026,3],"resumen":"usuario=Administrador GET /sistema-almacen/inventario.php -> SELECT tabla? params=[1,2026,3]","ok":true}
