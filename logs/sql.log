{"timestamp":"2026-03-20T20:23:09+01:00","request_id":"ffaab355-daf3-43d8-a2d0-5e32f2ff6146","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":0.575,"op":"SELECT","write":false,"tabla":null,"sql":"\n            SELECT e.id, e.referencia, e.factura, e.fecha, prov.nombre AS persona, e.estado,\n                   'in' AS tipo, de.cantidad, p.nombre AS item_nombre,\n                   e.created_at, e.created_by, u.nombre AS created_by_nombre\n            FROM entradas e\n            LEFT JOIN catalogo_proveedor prov ON prov.id = e.proveedor_id\n            JOIN detalle_entradas de ON de.entrada_id = e.id AND (de.estado = 'activa' OR de.estado IS NULL)\n            JOIN productos p ON p.id = de.producto_id\n            LEFT JOIN usuarios u ON u.id = e.created_by\n            WHERE 1=1 AND e.almacen_id = ?\n         ORDER BY e.created_at DESC, de.id DESC LIMIT 50","params_raw":[2],"resumen":"usuario=Arturo GET /sistema-almacen/transacciones.php -> SELECT tabla? params=[2]","ok":true}
{"timestamp":"2026-03-20T20:23:09+01:00","request_id":"ffaab355-daf3-43d8-a2d0-5e32f2ff6146","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":0.568,"op":"SELECT","write":false,"tabla":null,"sql":"\n            SELECT s.id, s.referencia, s.fecha, rec.nombre AS persona, s.estado,\n                   'out' AS tipo, ds.cantidad, p.nombre AS item_nombre,\n                   s.created_at, s.created_by, u.nombre AS created_by_nombre,\n                   qe.nombre AS nombre_entrega, pl.nombre AS plantel_nombre, rec.nombre AS nombre_receptor\n            FROM salidas s\n            LEFT JOIN catalogo_quien_entrega qe ON qe.id = s.quien_entrega_id\n            LEFT JOIN catalogo_plantel pl ON pl.id = s.plantel_id\n            LEFT JOIN catalogo_receptor rec ON rec.id = s.receptor_id\n            JOIN detalle_salidas ds ON ds.salida_id = s.id\n            JOIN productos p ON p.id = ds.producto_id\n            LEFT JOIN usuarios u ON u.id = s.created_by\n            WHERE 1=1 AND s.almacen_id = ?\n         ORDER BY s.created_at DESC, ds.id DESC LIMIT 50","params_raw":[2],"resumen":"usuario=Arturo GET /sistema-almacen/transacciones.php -> SELECT tabla? params=[2]","ok":true}
{"timestamp":"2026-03-20T20:23:09+01:00","request_id":"ffaab355-daf3-43d8-a2d0-5e32f2ff6146","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":0.213,"op":"SELECT","write":false,"tabla":null,"sql":"SELECT nombre FROM almacenes WHERE id = ? LIMIT 1","params_raw":[2],"resumen":"usuario=Arturo GET /sistema-almacen/transacciones.php -> SELECT tabla? params=[2]","ok":true}
{"timestamp":"2026-03-20T20:23:12+01:00","request_id":"f1d44bbc-2ec0-420f-8470-8f970dc3ec07","usuario_id":2,"usuario_nombre":"Arturo","duration_ms":0.775,"op":"SELECT","write":false,"tabla":null,"sql":"\r\n        SELECT s.id, s.referencia, s.fecha, s.estado, s.created_at,\r\n               qe.nombre AS nombre_entrega, pl.nombre AS plantel_nombre, rec.nombre AS nombre_receptor,\r\n               u.nombre AS created_by_nombre\r\n        FROM salidas s\r\n        LEFT JOIN catalogo_quien_entrega qe ON qe.id = s.quien_entrega_id\r\n        LEFT JOIN catalogo_plantel pl ON pl.id = s.plantel_id\r\n        LEFT JOIN catalogo_receptor rec ON rec.id = s.receptor_id\r\n        LEFT JOIN usuarios u ON u.id = s.created_by\r\n        WHERE s.almacen_id = ?\r\n          AND (s.recibo_entrega_doc IS NULL OR s.recibo_entrega_doc = '')\r\n          AND s.estado != 'cancelada'\r\n        ORDER BY s.fecha DESC, s.created_at DESC\r\n    ","params_raw":[2],"resumen":"usuario=Arturo GET /sistema-almacen/recibos.php -> SELECT tabla? params=[2]","ok":true}
